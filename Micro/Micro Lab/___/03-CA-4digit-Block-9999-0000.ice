                    {
                      "name": "Co"
                    }
                  ]
                },
                "params": [],
                "code": "reg [3:0] rCount;\nreg rCarry;\n\nalways@(posedge clk_i) begin\n    rCount <= rCount - 1;\n    if(rCount == 0) begin\n        rCount <= 9;\n        rCarry <= 1;\n    end\n    else rCarry <= 0;\nend\n\nassign Out = rCount;\nassign Co = rCarry;\n"
