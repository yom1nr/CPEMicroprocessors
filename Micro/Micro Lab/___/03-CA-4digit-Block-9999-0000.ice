      },
      "design": {
        "graph": {
          "blocks": [
            {
              "id": "d3ebc3e1-b64f-4d52-8802-aa11e1dfd9b2",
              "type": "basic.output",
              "data": {
                "name": "2Hz"
              },
              "position": {
                "x": 1072,
                "y": 192
              }
            },
            {
              "id": "4c2de183-bbba-45de-8157-881522b2e1c8",
              "type": "basic.input",
              "data": {
                "name": "ORGCLOCK",
                "clock": false
              },
              "position": {
                "x": 152,
                "y": 320
              }
            },
            {
              "id": "fc593f94-fc1d-4aba-a593-e1bfc78d1cbc",
              "type": "basic.output",
              "data": {
                "name": "2KHz"
              },
              "position": {
                "x": 1096,
                "y": 440
              }
            },
            {
              "id": "600495c6-2f23-4aa5-975a-a68ad458c30f",
              "type": "basic.code",
              "data": {
                "ports": {
                  "in": [
                    {
                      "name": "clk_i"
                    }
                  ],
                  "out": [
                    {
                      "name": "clk_2Hz"
                    },
                    {
                      "name": "clk_2kHz"
                    }
                  ]
                },
                "params": [],
                "code": "reg rQ2H = 1'b0;\nreg rQ2K = 1'b0;\nreg [27:0] CounterH;\nreg [27:0] CounterK;\nparameter fin = 12_000_000;\nparameter foutH = 2;\nparameter foutK = 2_000;\nparameter CoustH = fin/(2*foutH);\nparameter CoustK = fin/(2*foutK);\n\nalways@(posedge clk_i)\nbegin\n    CounterH <= CounterH + 1;\n    if(CounterH == CoustH)\n        begin\n            CounterH <= 0;\n            rQ2H <= ~rQ2H;\n        end\n    CounterK <= CounterK + 1;\n    if(CounterK == CoustK)\n        begin\n            CounterK <= 0;\n            rQ2K <= ~rQ2K;\n        end\nend\nassign clk_2kHz = rQ2K;\nassign clk_2Hz = rQ2H;"
              },
              "position": {
                "x": 376,
                "y": 104
              },
              "size": {
                "width": 560,
                "height": 488
              }
            }
          ],
          "wires": [
            {
              "source": {
                "block": "4c2de183-bbba-45de-8157-881522b2e1c8",
                "port": "out"
              },
              "target": {
                "block": "600495c6-2f23-4aa5-975a-a68ad458c30f",
                "port": "clk_i"
              }
            },
            {
              "source": {
                "block": "600495c6-2f23-4aa5-975a-a68ad458c30f",
                "port": "clk_2Hz"
              },
              "target": {
                "block": "d3ebc3e1-b64f-4d52-8802-aa11e1dfd9b2",
                "port": "in"
              }
            },
            {
              "source": {
                "block": "600495c6-2f23-4aa5-975a-a68ad458c30f",
                "port": "clk_2kHz"
              },
              "target": {
                "block": "fc593f94-fc1d-4aba-a593-e1bfc78d1cbc",
                "port": "in"
              }
            }
          ]
        }
      }
